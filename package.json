    "check": "bun fmt && bun lint",
    "fix": "bun fmt && bun lint:fix"
  },
  "dependencies": {
    "@nuxtjs/color-mode": "4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vueuse/nuxt": "14.2.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "nano-staged": {
    "*": "bun check"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.10"
